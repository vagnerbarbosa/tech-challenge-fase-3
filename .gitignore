# ========================================
# Tech Challenge Fase 3 - .gitignore
# ========================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Environment variables (IMPORTANTE: nunca commitar!)
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Logs
logs/
*.log

# Modelos treinados (muito grandes para git)
models/
*.pt
*.pth
*.bin
*.safetensors
*.gguf

# Dados brutos (sensíveis/grandes)
data/raw/
*.csv
*.json
*.parquet
!data/processed/.gitkeep
!data/raw/.gitkeep

# Cache
.cache/
*.cache
hf_cache/
.huggingface/

# MLOps
wandb/
mlruns/
outputs/
checkpoints/

# Sistema
.DS_Store
Thumbs.db
*.bak
*.tmp

# Testes
.coverage
htmlcov/
.pytest_cache/
.tox/

# Arquivos sensíveis de anonimização
*_original.*
*_raw.*
