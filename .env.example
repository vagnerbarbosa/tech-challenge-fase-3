# ==============================================
# Tech Challenge Fase 3 - Variáveis de Ambiente
# ==============================================

# Hugging Face
HUGGINGFACE_TOKEN=hf_your_token_here
HF_HOME=./models/huggingface_cache

# Modelo Base
BASE_MODEL_NAME=meta-llama/Llama-2-7b-chat-hf
# Alternativa: tiiuae/falcon-7b-instruct

# Caminhos do Projeto
MODEL_PATH=./models
DATA_PATH=./data
LOG_PATH=./logs

# Configurações de Treinamento
MAX_SEQ_LENGTH=512
BATCH_SIZE=4
LEARNING_RATE=2e-4
NUM_EPOCHS=3

# LangChain
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=tech-challenge-fase3

# Logging
LOG_LEVEL=INFO
