# ========================================
# Tech Challenge Fase 3 - Variáveis de Ambiente
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES
# ========================================

# === API Keys ===
# OpenAI (para embeddings e/ou modelo base)
OPENAI_API_KEY=sk-your-openai-key-here

# Hugging Face (para download de modelos)
HUGGINGFACE_TOKEN=hf_your-token-here

# Weights & Biases (opcional, para monitoramento)
WANDB_API_KEY=your-wandb-key-here
WANDB_PROJECT=tech-challenge-fase-3

# === Configurações do Modelo ===
# Modelo base para fine-tuning (LLaMA ou Falcon)
BASE_MODEL=meta-llama/Llama-2-7b-hf
MODEL_NAME=assistente-medico-v1

# === Caminhos ===
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# === Configurações de Treinamento ===
BATCH_SIZE=4
LEARNING_RATE=2e-5
NUM_EPOCHS=3
MAX_SEQ_LENGTH=512

# === Ambiente ===
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
