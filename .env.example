# ==============================================
# Tech Challenge Fase 3 - Variáveis de Ambiente
# Assistente Virtual Médico Generalista
# ==============================================

# Hugging Face
HF_TOKEN=hf_your_token_here
HF_HOME=./models/huggingface_cache

# Modelo Base
BASE_MODEL_NAME=BioMistral/BioMistral-7B
# Alternativa: tiiuae/falcon-7b-instruct

# Caminhos do Projeto
MODEL_PATH=./models
DATA_PATH=./data
LOG_PATH=./logs

# Configurações de Treinamento
# Ajustar conforme necessário para dados médicos gerais
MAX_SEQ_LENGTH=2048
BATCH_SIZE=4
LEARNING_RATE=2e-4
NUM_EPOCHS=3

# LangChain
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=tech-challenge-fase3-medical-assistant

# Logging
LOG_LEVEL=INFO
